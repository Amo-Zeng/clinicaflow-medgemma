# ClinicaFlow server/runtime configuration (example)

CLINICAFLOW_LOG_LEVEL=INFO
CLINICAFLOW_JSON_LOGS=false
CLINICAFLOW_DEBUG=false
CLINICAFLOW_MAX_REQUEST_BYTES=262144
CLINICAFLOW_POLICY_PACK_PATH=
CLINICAFLOW_POLICY_TOPK=2
CLINICAFLOW_CORS_ALLOW_ORIGIN=*
CLINICAFLOW_API_KEY=
CLINICAFLOW_PHI_GUARD=true
# Rolling window size for `/metrics` p50/p95 and recent error rate (default: 200)
CLINICAFLOW_METRICS_WINDOW=200

# Optional external reasoning backend
#
# - deterministic (default): no external calls
# - openai_compatible: OpenAI-compatible /v1/chat/completions (e.g. vLLM)
# - gradio_space: public HF Space (Gradio) root URL (demo-only)
# - hf_inference: HF router inference API (token required; demo-only)
CLINICAFLOW_REASONING_BACKEND=deterministic

# For openai_compatible:
CLINICAFLOW_REASONING_BASE_URL=http://127.0.0.1:8001
CLINICAFLOW_REASONING_MODEL=
CLINICAFLOW_REASONING_API_KEY=

# For gradio_space (optional pool via BASE_URLS; per-entry api_name via |):
# CLINICAFLOW_REASONING_BASE_URLS='https://senthil3226w-medgemma-4b-it.hf.space|chat,https://eminkarka1-cortix-medgemma.hf.space|predict'
# CLINICAFLOW_REASONING_GRADIO_API_NAME=chat

# For hf_inference (defaults BASE_URL to HF router; requires token):
# CLINICAFLOW_REASONING_BASE_URL=https://router.huggingface.co/hf-inference
# CLINICAFLOW_REASONING_MODEL=google/medgemma-4b-it
# CLINICAFLOW_REASONING_API_KEY=<HF_TOKEN>
# CLINICAFLOW_REASONING_HF_WAIT_FOR_MODEL=1

CLINICAFLOW_REASONING_TIMEOUT_S=30
CLINICAFLOW_REASONING_MAX_RETRIES=1
CLINICAFLOW_REASONING_RETRY_BACKOFF_S=0.5
CLINICAFLOW_REASONING_TEMPERATURE=0.2
CLINICAFLOW_REASONING_MAX_TOKENS=600

# Optional communication rewrite backend (rewrite-only; may reuse MedGemma)
#
# - deterministic (default): no external calls
# - openai_compatible: OpenAI-compatible /v1/chat/completions (e.g. vLLM)
# - gradio_space: public HF Space (Gradio) root URL (demo-only)
# - hf_inference: HF router inference API (token required; demo-only)
CLINICAFLOW_COMMUNICATION_BACKEND=deterministic
CLINICAFLOW_COMMUNICATION_BASE_URL=
CLINICAFLOW_COMMUNICATION_MODEL=
CLINICAFLOW_COMMUNICATION_API_KEY=
CLINICAFLOW_COMMUNICATION_TIMEOUT_S=30
CLINICAFLOW_COMMUNICATION_MAX_RETRIES=1
CLINICAFLOW_COMMUNICATION_RETRY_BACKOFF_S=0.5
CLINICAFLOW_COMMUNICATION_MAX_TOKENS=600

# Optional external evidence backend (free public APIs; no API keys)
#
# - local (default): policy pack only (offline)
# - pubmed: NCBI E-utilities (PubMed)
# - medlineplus: NLM wsearch (MedlinePlus Health Topics)
# - crossref: Crossref works API (general scholarly fallback)
# - openalex: OpenAlex works API (general scholarly fallback)
# - clinicaltrials: ClinicalTrials.gov API v2 (trial links; fallback)
# - auto: pubmed → medlineplus → crossref → openalex → clinicaltrials
CLINICAFLOW_EVIDENCE_BACKEND=local
CLINICAFLOW_EVIDENCE_TIMEOUT_S=2.5
CLINICAFLOW_EVIDENCE_MAX_RESULTS=3
CLINICAFLOW_EVIDENCE_CACHE_TTL_S=3600
# Optional (recommended by NCBI for E-utilities etiquette; no secrets):
CLINICAFLOW_EVIDENCE_PUBMED_TOOL=clinicaflow
CLINICAFLOW_EVIDENCE_PUBMED_EMAIL=
